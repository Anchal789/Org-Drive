{
  "name": "next-js-boilerplate",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "next.js",
    "tailwindcss",
    "biome",
    "boilerplate"
  ],
  "description": "Next.js boilerplate with Tailwind CSS, Biome",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:staged": "lint-staged"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/adapter-ppg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "critters": "0.0.25",
    "dotenv": "17.4.2",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "prisma": "7.8.0",
    "qrcode": "1.5.4",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "shadcn": "4.8.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "telegram": "2.26.22",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "25.8.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "postcss": "8.5.14",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "typescript": "6.0.3"
  },
  "browserslist": "defaults",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
