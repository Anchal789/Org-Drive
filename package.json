{
  "name": "next-js-boilerplate",
  "version": "1.0.0",
  "packageManager": "pnpm@10.17.1",
  "private": true,
  "keywords": [
    "next.js",
    "tailwindcss",
    "biome",
    "boilerplate"
  ],
  "description": "Next.js boilerplate with Tailwind CSS, Biome",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:staged": "lint-staged",
    "doctor": "react-doctor",
    "doctor:diff": "react-doctor --diff",
    "doctor:staged": "react-doctor --staged",
    "doctor:advisory": "react-doctor --blocking none",
    "doctor:full": "react-doctor --diff false",
    "doctor:json": "react-doctor --json"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@hookform/resolvers": "5.4.0",
    "archiver": "8.0.0",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "critters": "0.0.25",
    "crypto-js": "4.2.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "jose": "6.2.3",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "pg": "8.21.0",
    "postgres": "3.4.9",
    "qrcode": "1.5.4",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "server-only": "0.0.1",
    "shadcn": "4.8.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "telegram": "2.26.22",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/archiver": "8.0.0",
    "@types/bcryptjs": "2.4.6",
    "@types/crypto-js": "4.2.2",
    "@types/node": "25.8.0",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "0.31.10",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "postcss": "8.5.14",
    "react-doctor": "0.5.1",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "browserslist": "defaults"
}
