# ==========================================
# Database Configuration
# ==========================================
# Local database example:
DATABASE_URL="postgresql://username:password@localhost:5432/orgdrive_db"
# Cloud database example (e.g., Render, Supabase):
# DATABASE_URL="postgresql://user:password@host.render.com/dbname?sslmode=require"

# ==========================================
# Telegram Configuration
# ==========================================
# Get Bot Token from @BotFather
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Get API ID and Hash from my.telegram.org
TELEGRAM_APP_API_ID=your_telegram_api_id_here
TELEGRAM_APP_API_HASH="your_telegram_api_hash_here"

# The ID of the private channel where files will be stored (usually starts with -100)
TELEGRAM_STORAGE_CHANNEL_ID=-100xxxxxxxxxx

# ==========================================
# Security & Authentication
# ==========================================
# Secret key for signing JSON Web Tokens
JWT_SECRET="your_secure_jwt_secret_key_here"

# Keys for obfuscation and secure cron jobs
APP_SECRET_KEY="your_public_phone_obfuscation_key_here"
NEXT_PRIVATE_CRON_SECRET="your_private_cron_secret_here"

# Shared secret between the Next.js app and auth-server for the
# server-to-server QR-login handoff (never exposed to the browser)
AUTH_SERVER_INTERNAL_SECRET="your_auth_server_internal_secret_here"
